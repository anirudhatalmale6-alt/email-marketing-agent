generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("member")
  email     String?
  createdAt DateTime @default(now())

  leads       Lead[]
  templates   Template[]
  campaigns   Campaign[]
  smtpConfigs SmtpConfig[]
  tags        Tag[]
  calls       Call[]
}

model Lead {
  id            String   @id @default(uuid())
  email         String
  firstName     String
  lastName      String
  company       String?
  jobTitle      String?
  phone         String?
  country       String?
  city          String?
  website       String?
  source        String?
  verified      Boolean  @default(false)
  status        String   @default("new")
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?    @relation(fields: [userId], references: [id])
  tags          LeadTag[]
  campaignLeads CampaignLead[]
  emailEvents   EmailEvent[]
  calls         Call[]

  @@unique([email, userId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#3B82F6")
  userId    String?
  createdAt DateTime @default(now())

  user  User?     @relation(fields: [userId], references: [id])
  leads LeadTag[]

  @@unique([name, userId])
}

model LeadTag {
  id     String @id @default(uuid())
  leadId String
  tagId  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
}

model Template {
  id          String   @id @default(uuid())
  name        String
  subject     String
  htmlContent String
  jsonLayout  String?
  category    String   @default("general")
  thumbnail   String?
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id])
  campaigns Campaign[]
}

model Campaign {
  id            String    @id @default(uuid())
  name          String
  subject       String
  status        String    @default("draft")
  templateId    String?
  segmentTags   String?
  directEmails  String?
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  dailyLimit    Int       @default(300)
  delaySeconds  Int       @default(30)
  aiPersonalize Boolean   @default(false)
  followUpEnabled Boolean @default(false)
  followUpDays    Int     @default(3)
  followUpMaxCount Int    @default(2)
  fromName      String?
  fromEmail     String?
  smtpConfigId  String?
  userId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?          @relation(fields: [userId], references: [id])
  template      Template?      @relation(fields: [templateId], references: [id])
  campaignLeads CampaignLead[]
}

model CampaignLead {
  id          String    @id @default(uuid())
  campaignId  String
  leadId      String
  status      String    @default("pending")
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  followUpCount Int     @default(0)
  personalizedSubject String?
  personalizedBody    String?
  createdAt   DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  events   EmailEvent[]

  @@unique([campaignId, leadId])
}

model EmailEvent {
  id             String   @id @default(uuid())
  campaignLeadId String
  leadId         String
  type           String
  metadata       String?
  createdAt      DateTime @default(now())

  campaignLead CampaignLead @relation(fields: [campaignLeadId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id       String  @id @default(uuid())
  name     String
  host     String
  port     Int
  secure   Boolean @default(true)
  username String
  password String
  fromName String
  fromEmail String
  isDefault Boolean @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model UploadedImage {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  data      String
  createdAt DateTime @default(now())
}

model Call {
  id           String   @id @default(uuid())
  leadId       String?
  userId       String?
  callType     String   @default("prospect") // 'prospect' (new) or 'customer' (existing)
  toNumber     String
  blandCallId  String?
  status       String   @default("queued") // queued, initiated, completed, failed
  answeredBy   String?  // human, voicemail, no-answer, unknown
  outcome      String?  // interested, reorder, callback, not_interested, no_answer
  summary      String?
  transcript   String?
  recordingUrl String?
  durationSec  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id])
}
