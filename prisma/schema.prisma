generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Lead {
  id            String   @id @default(uuid())
  email         String   @unique
  firstName     String
  lastName      String
  company       String?
  jobTitle      String?
  phone         String?
  country       String?
  city          String?
  website       String?
  source        String?
  verified      Boolean  @default(false)
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tags          LeadTag[]
  campaignLeads CampaignLead[]
  emailEvents   EmailEvent[]
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())

  leads LeadTag[]
}

model LeadTag {
  id     String @id @default(uuid())
  leadId String
  tagId  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
}

model Template {
  id          String   @id @default(uuid())
  name        String
  subject     String
  htmlContent String
  jsonLayout  String?
  category    String   @default("general")
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns Campaign[]
}

model Campaign {
  id            String    @id @default(uuid())
  name          String
  subject       String
  status        String    @default("draft")
  templateId    String?
  segmentTags   String?
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  dailyLimit    Int       @default(300)
  delaySeconds  Int       @default(30)
  aiPersonalize Boolean   @default(false)
  followUpEnabled Boolean @default(false)
  followUpDays    Int     @default(3)
  followUpMaxCount Int    @default(2)
  fromName      String?
  fromEmail     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  template      Template?      @relation(fields: [templateId], references: [id])
  campaignLeads CampaignLead[]
}

model CampaignLead {
  id          String    @id @default(uuid())
  campaignId  String
  leadId      String
  status      String    @default("pending")
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  followUpCount Int     @default(0)
  personalizedSubject String?
  personalizedBody    String?
  createdAt   DateTime  @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  events   EmailEvent[]

  @@unique([campaignId, leadId])
}

model EmailEvent {
  id             String   @id @default(uuid())
  campaignLeadId String
  leadId         String
  type           String
  metadata       String?
  createdAt      DateTime @default(now())

  campaignLead CampaignLead @relation(fields: [campaignLeadId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id       String  @id @default(uuid())
  name     String
  host     String
  port     Int
  secure   Boolean @default(true)
  username String
  password String
  fromName String
  fromEmail String
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
